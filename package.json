{
  "name": "jobswipe-mvp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env TIME_ZONE=Asia/Tokyo next dev -p 3010",
    "build": "prisma generate && cross-env TIME_ZONE=Asia/Tokyo next build",
    "start": "cross-env TIME_ZONE=Asia/Tokyo next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "cross-env TIME_ZONE=Asia/Tokyo prisma db seed",
    "storage:setup": "node --env-file=.env scripts/setup-storage-buckets.mjs",
    "storage:setup-resumes": "npm run storage:setup",
    "storage:scan": "node --env-file=.env scripts/scan-storage-urls.mjs",
    "storage:migrate": "tsx --env-file=.env scripts/migrate-supabase-storage-to-r2.ts",
    "storage:migrate:dry-run": "tsx --env-file=.env scripts/migrate-supabase-storage-to-r2.ts --dry-run",
    "pwa:icons": "node scripts/generate-pwa-icons.mjs",
    "assets:webp": "node scripts/optimize-images-webp.mjs",
    "assets:optimize": "npm run assets:webp && npm run pwa:icons",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1076.0",
    "@aws-sdk/lib-storage": "^3.1076.0",
    "@aws-sdk/s3-request-presigner": "^3.1076.0",
    "@prisma/client": "^6.19.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "formik": "^2.4.9",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.9.0",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^6.19.0",
    "sharp": "^0.35.2",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  }
}
