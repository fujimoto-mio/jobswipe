generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum CompanyStatus {
  Active
  Pending
  Suspended
}

enum SeekerStatus {
  Active
  Suspended
}

enum JobApprovalStatus {
  Draft
  Pending
  Active
  Cancelled
}

enum JobSubmissionStatus {
  Pending
  Approved
  Rejected
}

enum AuthCredentialRole {
  seeker
  company
  admin
}

model Company {
  id          String   @id @default(uuid())
  name        String   @unique
  logoUrl     String?  @map("logo_url")
  bannerUrl   String?  @map("banner_url")
  description String?
  website     String?
  postalCode  String?  @map("postal_code")
  address     String?
  links       Json     @default("{}")
  status      CompanyStatus @default(Active)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  jobs        Job[]
  accounts    Account[]

  @@map("companies")
}

model Job {
  id             String   @id @default(uuid())
  companyId      String   @map("company_id")
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title          String
  location       String
  area           String
  category       String
  salaryDisplay  String   @map("salary_display")
  employmentType String   @map("employment_type")
  description    String
  requirements   Json     @default("[]")
  benefits       Json     @default("[]")
  tags           Json     @default("[]")
  videoUrl       String   @map("video_url")
  thumbnailUrl   String?  @map("thumbnail_url")
  links          Json     @default("{}")
  approvalStatus JobApprovalStatus @default(Draft) @map("approval_status")
  approvedAt     DateTime? @map("approved_at") @db.Timestamptz(3)
  viewCount      Int      @default(0) @map("view_count")
  postedAt       DateTime @default(now()) @map("posted_at") @db.Timestamptz(3)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  savedJobs    SavedJob[]
  applications Application[]
  submissions  JobSubmission[]

  @@index([companyId])
  @@index([approvalStatus, postedAt(sort: Desc)])
  @@map("jobs")
}

model JobSubmission {
  id             String              @id @default(uuid())
  jobId          String              @map("job_id")
  job            Job                 @relation(fields: [jobId], references: [id], onDelete: Cascade)
  title          String
  location       String
  area           String
  category       String
  salaryDisplay  String              @map("salary_display")
  employmentType String              @map("employment_type")
  description    String
  requirements   Json                @default("[]")
  benefits       Json                @default("[]")
  tags           Json                @default("[]")
  videoUrl       String              @map("video_url")
  thumbnailUrl   String?             @map("thumbnail_url")
  links          Json                @default("{}")
  status         JobSubmissionStatus @default(Pending)
  submittedAt    DateTime            @default(now()) @map("submitted_at") @db.Timestamptz(3)
  reviewedAt     DateTime?           @map("reviewed_at") @db.Timestamptz(3)
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([status, submittedAt(sort: Desc)])
  @@index([jobId, status])
  @@map("job_submissions")
}

/// Authenticated staff accounts (admin / company) — linked to auth_credentials.id
model Account {
  id        String   @id
  email     String   @unique
  name      String?
  avatarUrl String?  @map("avatar_url")
  role      String   // admin | company
  companyId String?  @map("company_id")
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([role])
  @@index([companyId])
  @@map("accounts")
}

model SeekerProfile {
  id             String   @id @default(uuid())
  email          String   @unique
  name           String
  gender         String
  birthday       DateTime @db.Date
  area           String
  desiredJobType String   @map("desired_job_type")
  experience     String
  employmentType String   @map("employment_type")
  introSentence  String?  @map("intro_sentence")
  profileTitle   String?  @map("profile_title")
  resumeUrl      String?  @map("resume_url")
  futureGoals    String?  @map("future_goals") @db.Text
  desiredSalary  String?  @map("desired_salary")
  jobSearchIntent String? @map("job_search_intent")
  education      String?
  phone          String?
  address        String?
  portfolioUrl   String?  @map("portfolio_url")
  avatarUrl      String?  @map("avatar_url")
  bannerUrl      String?  @map("banner_url")
  skills         Json     @default("[]")
  workHistory    Json     @default("[]") @map("work_history")
  supabaseUserId String   @unique @map("supabase_user_id")
  notifyHiredEmail Boolean @default(true) @map("notify_hired_email")
  notifyChatEmail  Boolean @default(true) @map("notify_chat_email")
  status           SeekerStatus @default(Active)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  savedJobs    SavedJob[]
  applications Application[]

  @@map("seeker_profiles")
}

model AuthCredential {
  id           String             @id @default(uuid())
  email        String             @unique
  passwordHash String             @map("password_hash")
  role         AuthCredentialRole
  createdAt    DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([role])
  @@map("auth_credentials")
}

model SavedJob {
  id        String        @id @default(uuid())
  seekerId  String        @map("seeker_id")
  jobId     String        @map("job_id")
  message   String?       @db.Text
  seeker    SeekerProfile @relation(fields: [seekerId], references: [id], onDelete: Cascade)
  job       Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)

  @@unique([seekerId, jobId])
  @@index([seekerId, createdAt(sort: Desc)])
  @@map("saved_jobs")
}

model Application {
  id               String        @id @default(uuid())
  seekerId         String        @map("seeker_id")
  jobId            String        @map("job_id")
  applicantName    String        @map("applicant_name")
  applicantEmail   String        @map("applicant_email")
  applicantBirthday DateTime?     @map("applicant_birthday") @db.Date
  applicantArea    String?       @map("applicant_area")
  applicantJobType String?       @map("applicant_job_type")
  message          String?
  status           String        @default("new")
  interviewSlot    String?       @map("interview_slot")
  interviewBookedAt DateTime?    @map("interview_booked_at") @db.Timestamptz(3)
  matchEmailSentAt DateTime?     @map("match_email_sent_at") @db.Timestamptz(3)
  seekerReadAt     DateTime?     @map("seeker_read_at") @db.Timestamptz(3)
  companyReadAt    DateTime?     @map("company_read_at") @db.Timestamptz(3)
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)

  seeker   SeekerProfile @relation(fields: [seekerId], references: [id], onDelete: Cascade)
  job      Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@unique([seekerId, jobId])
  @@index([status, createdAt(sort: Desc)])
  @@index([jobId])
  @@map("applications")
}

model ChatMessage {
  id              String      @id @default(uuid())
  applicationId   String      @map("application_id")
  sender          String
  senderName      String?     @map("sender_name")
  senderAvatarUrl String?     @map("sender_avatar_url")
  content         String
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz(3)

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId, createdAt])
  @@map("chat_messages")
}
