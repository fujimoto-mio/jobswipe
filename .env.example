# Server timezone (Japan Standard Time, UTC+9)
TIME_ZONE=Asia/Tokyo

# App auth — local JWT in httpOnly cookie (no Supabase Auth round-trip per API call)
AUTH_JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
AUTH_JWT_EXPIRES_IN=7d

# Supabase — Realtime chat broadcast + Postgres (auth no longer required for login)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Prisma → Supabase PostgreSQL
# Dashboard → Connect → copy the exact host (may be aws-0, aws-1, etc. — do not guess)
# Transaction pooler (port 6543)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Session pooler for migrations / db push (port 5432)
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"

# Admin seed (npm run db:seed) — creates auth credential + accounts row
ADMIN_SEED_EMAIL=admin@jobswipe.app
ADMIN_SEED_PASSWORD=change-me-to-a-strong-password
ADMIN_SEED_NAME=システム管理者

# Company staff seed — creates auth credential + company row + account
COMPANY_SEED_EMAIL=company@jobswipe.app
COMPANY_SEED_PASSWORD=change-me-to-a-strong-password
COMPANY_SEED_NAME=採用担当者
COMPANY_SEED_COMPANY_NAME=テックスタート株式会社

# SMTP — outbound email (contact form, match notifications, etc.)
SUPPORT_EMAIL=jobswipe@maskoff.co.jp
SMTP_HOST=smtp.muumuu-mail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=jobswipe@maskoff.co.jp
SMTP_PASS=your-smtp-password
# Optional — defaults to JobSwipe <SMTP_USER> when omitted
EMAIL_FROM=JobSwipe <jobswipe@maskoff.co.jp>

# Optional — support mailto link in seeker settings (display only)
NEXT_PUBLIC_SUPPORT_EMAIL=jobswipe@maskoff.co.jp

# Google Analytics (gtag.js) — omit to disable tracking
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-W63BYL2X4E
# Calendly — interview booking embed (§2.3)
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-account/30min

# Cloudflare R2 — two buckets: public media + private (chat/resumes)
# Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_PUBLIC=jobswipe-public
R2_BUCKET_PRIVATE=jobswipe-private
# Recommended — stable CDN URL for public bucket (job videos, logos, avatars)
# R2 dashboard → bucket → Settings → Public access → Connect custom domain (or r2.dev for dev)
R2_PUBLIC_BUCKET_URL=https://pub-998c4ca522a64e85a2ba30b1e61ee7a2.r2.dev
# Optional — stable CDN URL for private bucket reads (resumes, chat attachments)
# R2_PRIVATE_BUCKET_URL=https://pub-yyyyyyyy.r2.dev
